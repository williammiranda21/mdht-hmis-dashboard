# Copy to .env.local and fill in from Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Secret — used only by the pipeline upsert (server side). Never commit. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# NOTE: BNL_PIN_SHA256 is no longer used — the By-Name List is now behind
# Supabase Auth (email + password) with an admins-only RLS policy. You can
# delete BNL_PIN_SHA256 from your .env.local.
